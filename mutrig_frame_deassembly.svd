<?xml version="1.0" encoding="UTF-8"?>
<device schemaVersion="1.3" xmlns:xs="http://www.w3.org/2001/XMLSchema-instance" xs:noNamespaceSchemaLocation="CMSIS-SVD.xsd">
  <vendor>Mu3e</vendor>
  <vendorID>MU3E</vendorID>
  <name>MU3E_MUTRIG_FRAME_DEASSEMBLY</name>
  <series>MU3E_FPGA_IP</series>
  <version>26.0.402</version>
  <description>CMSIS-SVD description of the mutrig_frame_deassembly CSR window. This first-pass schema exposes the 4-word relative aperture as read-only WORD registers until the IP author publishes field-accurate semantics.</description>
  <addressUnitBits>8</addressUnitBits>
  <width>32</width>
  <size>32</size>
  <access>read-write</access>
  <resetValue>0x00000000</resetValue>
  <resetMask>0xFFFFFFFF</resetMask>
  <peripherals>
    <peripheral>
      <name>MUTRIG_FRAME_DEASSEMBLY_CSR</name>
      <description>Relative 4-word CSR aperture for MuTRiG frame deassembly.</description>
      <groupName>MU3E_DATA_PATH</groupName>
      <baseAddress>0x0</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x10</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>WORD000</name>
          <description>MuTRiG frame deassembly CSR word 0.</description>
          <addressOffset>0x0</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>value</name>
              <description>Raw MuTRiG frame deassembly CSR word 0.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>WORD001</name>
          <description>MuTRiG frame deassembly CSR word 1.</description>
          <addressOffset>0x4</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>value</name>
              <description>Raw MuTRiG frame deassembly CSR word 1.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>WORD002</name>
          <description>MuTRiG frame deassembly CSR word 2.</description>
          <addressOffset>0x8</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>value</name>
              <description>Raw MuTRiG frame deassembly CSR word 2.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>WORD003</name>
          <description>MuTRiG frame deassembly CSR word 3.</description>
          <addressOffset>0xC</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>value</name>
              <description>Raw MuTRiG frame deassembly CSR word 3.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
  </peripherals>
</device>
